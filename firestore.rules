rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: items
    // Document ID: itemId (auto-generated)
    // Fields:
    //   - uid: string (required) - User ID of the owner
    //   - name: string (required) - Name of the item
    //   - category: string (required) - electronics, medicine, food, cosmetics
    //   - expiryDate: string (required) - ISO 8601 date
    //   - purchaseDate: string (optional) - ISO 8601 date
    //   - notes: string (optional)
    //   - imageUrl: string (optional)
    //   - createdAt: string (required) - ISO 8601 date-time
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function isValidItem(data) {
      return data.keys().hasAll(['uid', 'name', 'category', 'expiryDate', 'createdAt']) &&
             data.uid is string &&
             data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.category in ['electronics', 'medicine', 'food', 'cosmetics'] &&
             data.expiryDate is string && data.expiryDate.matches("^\\d{4}-\\d{2}-\\d{2}.*") &&
             data.createdAt is string;
    }

    match /items/{itemId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && 
                      request.resource.data.uid == request.auth.uid &&
                      isValidItem(request.resource.data);
      allow update: if isDocOwner() && 
                      request.resource.data.uid == resource.data.uid &&
                      isValidItem(request.resource.data);
      allow delete: if isDocOwner();
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }
  }
}
